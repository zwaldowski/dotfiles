// Zed settings
// - `zed: open default settings`
// - <https://zed.dev/docs/configuring-zed>
{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Macchiato",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Macchiato",
    "dark": "Catppuccin Macchiato",
  },
  "buffer_font_family": "SF Mono",
  "buffer_font_size": 12,
  "buffer_font_weight": 540.0,
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 17,
  "restore_on_startup": "empty_tab",
  "zoomed_padding": false,
  "calls": {
    "mute_on_join": true,
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_picture": false,
  },
  "minimap": {
    "show": "never",
  },
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "outline_panel": {
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "tabs": {
    "close_position": "left",
  },
  "ensure_final_newline_on_save": false,
  "soft_wrap": "prefer_line",
  "telemetry": {
    "metrics": false,
  },
  "disable_ai": true,
  "edit_predictions": {
    "provider": "none",
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "csv": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "pbxproj": true,
    "swift": true,
  },
  "lsp": {
    "sourcekit-lsp": {
      "binary": {
        "path": "/var/db/xcode_select_link/Toolchains/XcodeDefault.xctoolchain/usr/bin/sourcekit-lsp",
      },
    },
  },
  "debugger": {
    "dock": "left",
  },
}
